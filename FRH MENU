-- ============================================================
local function isInSafeZone(position)
    if not position then return false end
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part:FindFirstChild("Humanoid") == nil then
            for _, safeName in pairs(SAFE_ZONES) do
                if string.find(string.lower(part.Name), string.lower(safeName)) then
                    if (position - part.Position).Magnitude < 20 then return true end
                end
            end
        end
    end
    return false
end

local function verificarParede(part, character)
    if not AimbotConfig.WallCheck then return true end
    local origin = camera.CFrame.Position
    local direction = (part.Position - origin).Unit * (part.Position - origin).Magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {player.Character}
    raycastParams.IgnoreWater = true
    local result = workspace:Raycast(origin, direction, raycastParams)
    if result then
        local hitPart = result.Instance
        if hitPart and hitPart:IsDescendantOf(character) then return true end
        return false
    end
    return true
end

-- ============================================================
-- HITBOX (SEM COLISÃO)
-- ============================================================
local function aplicarHitbox()
    pcall(function()
        for _, v in pairs(Players:GetPlayers()) do
            if v == player or not v.Character then continue end
            
            if not deveMostrarParaJogador(v) then
                local char = v.Character
                local head = char:FindFirstChild("Head")
                local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                
                if head then
                    head.Size = Vector3.new(1.2, 1.2, 1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                    head.Massless = false
                end
                if torso then
                    local defaultSize = char:FindFirstChild("UpperTorso") and Vector3.new(1.6, 1.6, 1) or Vector3.new(2, 2, 1)
                    torso.Size = defaultSize
                    torso.Transparency = 0
                    torso.CanCollide = true
                    torso.Massless = false
                end
                continue
            end
            
            local char = v.Character
            local head = char:FindFirstChild("Head")
            local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
            
            if AimbotConfig.SilentAim then
                if head then
                    head.Size = Vector3.new(10, 10, 10)
                    head.Transparency = 0.99
                    head.CanCollide = false
                    head.Massless = true
                    head.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                end
                if torso then
                    local defaultSize = char:FindFirstChild("UpperTorso") and Vector3.new(1.6, 1.6, 1) or Vector3.new(2, 2, 1)
                    torso.Size = defaultSize
                    torso.Transparency = 0
                    torso.CanCollide = true
                    torso.Massless = false
                end
            else
                if HitboxConfig.headEnabled and head then
                    head.Size = Vector3.new(HitboxConfig.headSize, HitboxConfig.headSize, HitboxConfig.headSize)
                    head.Transparency = HitboxConfig.transparency
                    head.CanCollide = false
                    head.Massless = true
                    head.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                elseif head then
                    head.Size = Vector3.new(1.2, 1.2, 1.2)
                    head.Transparency = 0
                    head.CanCollide = true
                    head.Massless = false
                    head.CustomPhysicalProperties = nil
                end
                if HitboxConfig.torsoEnabled and torso then
                    torso.Size = Vector3.new(HitboxConfig.torsoSize, HitboxConfig.torsoSize, HitboxConfig.torsoSize)
                    torso.Transparency = HitboxConfig.transparency
                    torso.CanCollide = false
                    torso.Massless = true
                    torso.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                elseif torso then
                    local defaultSize = char:FindFirstChild("UpperTorso") and Vector3.new(1.6, 1.6, 1) or Vector3.new(2, 2, 1)
                    torso.Size = defaultSize
                    torso.Transparency = 0
                    torso.CanCollide = true
                    torso.Massless = false
                    torso.CustomPhysicalProperties = nil
                end
            end
        end
    end)
end

