-- ============================================================
local function CarregarConfiguracoes()
    pcall(function()
        local data = HttpService:JSONDecode(readfile(ConfigFileName))
        if data then
            for key, value in pairs(data) do
                if AimbotConfig[key] ~= nil then
                    if typeof(value) == "string" and (key == "MenuKey" or key == "NoclipKey" or key == "FlyKey") then
                        local success, enum = pcall(function() return Enum.KeyCode[value] end)
                        if success and enum then AimbotConfig[key] = enum end
                    else AimbotConfig[key] = value end
                end
                if VisualConfig[key] ~= nil then
                    VisualConfig[key] = value
                end
                if HitboxConfig[key] ~= nil then HitboxConfig[key] = value end
                if MicsConfig[key] ~= nil then
                    if key == "MenuKey" and type(value) == "string" then
                        local success, enum = pcall(function() return Enum.KeyCode[value] end)
                        if success and enum then MicsConfig[key] = enum end
                    else MicsConfig[key] = value end
                end
                if PlayerConfig[key] ~= nil then
                    if (key == "NoclipKey" or key == "FlyKey") and type(value) == "string" then
                        local success, enum = pcall(function() return Enum.KeyCode[value] end)
                        if success and enum then PlayerConfig[key] = enum end
                    else PlayerConfig[key] = value end
                end
            end
        end
    end)
end

local function SalvarConfiguracoes()
    pcall(function()
        local dados = {}
        for key, value in pairs(AimbotConfig) do
            if type(value) ~= "function" then
                if typeof(value) == "EnumItem" then dados[key] = tostring(value)
                else dados[key] = value end
            end
        end
        for key, value in pairs(VisualConfig) do
            if type(value) ~= "function" then
                if typeof(value) == "EnumItem" then dados[key] = tostring(value)
                else dados[key] = value end
            end
        end
        for key, value in pairs(HitboxConfig) do
            if type(value) ~= "function" then dados[key] = value end
        end
        for key, value in pairs(MicsConfig) do
            if type(value) ~= "function" then
                if typeof(value) == "EnumItem" then dados[key] = tostring(value) else dados[key] = value end
            end
        end
        for key, value in pairs(PlayerConfig) do
            if type(value) ~= "function" then
                if typeof(value) == "EnumItem" then dados[key] = tostring(value) else dados[key] = value end
            end
        end
        writefile(ConfigFileName, HttpService:JSONEncode(dados))
    end)
end

