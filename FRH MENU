local function createBindSystem(text, configKey, targetTable, parent, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 0, 34)
    container.BackgroundColor3 = BG_CARD
    container.BorderSizePixel = 0
    container.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.4, 0, 1, 0)
    label.Position = UDim2.new(0, 6, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = TEXT_WHITE
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container

    local keyLabel = Instance.new("TextLabel")
    keyLabel.Size = UDim2.new(0.25, 0, 1, 0)
    keyLabel.Position = UDim2.new(0.45, 0, 0, 0)
    keyLabel.BackgroundTransparency = 1
    local currentKey = targetTable[configKey]
    keyLabel.Text = currentKey and tostring(currentKey):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "") or "NENHUMA"
    keyLabel.TextColor3 = PURPLE
    keyLabel.Font = Enum.Font.GothamBold
    keyLabel.TextSize = 12
    keyLabel.TextXAlignment = Enum.TextXAlignment.Center
    keyLabel.Parent = container

    local bindBtn = Instance.new("TextButton")
    bindBtn.Size = UDim2.new(0, 60, 0, 22)
    bindBtn.Position = UDim2.new(1, -70, 0.5, -11)
    bindBtn.BackgroundColor3 = PURPLE
    bindBtn.Text = "BIND"
    bindBtn.TextColor3 = TEXT_WHITE
    bindBtn.Font = Enum.Font.GothamBold
    bindBtn.TextSize = 10
    bindBtn.Parent = container

    local bindBtnCorner = Instance.new("UICorner")
    bindBtnCorner.CornerRadius = UDim.new(0, 4)
    bindBtnCorner.Parent = bindBtn

    bindBtn.MouseButton1Click:Connect(function()
        if waitingForBind then
            waitingForBind = false
            waitingForBindType = ""
            bindBtn.Text = "BIND"
            bindBtn.BackgroundColor3 = PURPLE
            return
        end

        waitingForBind = true
        waitingForBindType = configKey
        bindBtn.Text = "AGUARDANDO..."
        bindBtn.BackgroundColor3 = Color3.fromRGB(239, 68, 68)

        local function processBindKey(input)
            if not waitingForBind or waitingForBindType ~= configKey then return end
            local bindValue = nil
            if input.UserInputType == Enum.UserInputType.Keyboard then
                bindValue = input.KeyCode
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.MouseButton2 or
                   input.UserInputType == Enum.UserInputType.MouseButton3 then
                bindValue = input.UserInputType
            else
                return
            end
            if bindValue == Enum.KeyCode.Unknown then return end

            targetTable[configKey] = bindValue
            keyLabel.Text = tostring(bindValue):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
            waitingForBind = false
            waitingForBindType = ""
            bindBtn.Text = "BIND"
            bindBtn.BackgroundColor3 = PURPLE
            if callback then callback(bindValue) end
            SalvarConfiguracoes()
        end

        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            processBindKey(input)
            if not waitingForBind then
                connection:Disconnect()
            end
        end)
    end)

    return container
end

