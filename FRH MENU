-- ============================================================
-- LOOP PRINCIPAL
-- ============================================================
local LastCameraRotation = camera.CFrame.Rotation
local CurrentTarget = nil
local frameCount = 0

RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    
    if frameCount % 3 ~= 0 then return end
    
    pcall(function()
        -- FOV Circle
        FOVCircle.Visible = AimbotConfig.ShowFOV and screenGui.Enabled
        if FOVCircle.Visible then
            FOVCircle.Radius = AimbotConfig.FOVSize
            FOVCircle.Position = UserInputService:GetMouseLocation()
            FOVCircle.Color = WHITE
        end

        -- No Recoil
        if MicsConfig.NoRecoil then
            if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                camera.CFrame = CFrame.new(camera.CFrame.Position) * LastCameraRotation
            else
                LastCameraRotation = camera.CFrame.Rotation
            end
        end

        -- Silent Aim
        if AimbotConfig.SilentAim and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local targets = {}
            local mousePos = UserInputService:GetMouseLocation()
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character and deveMostrarParaJogador(p) then
                    local char = p.Character
                    local humanoid = char:FindFirstChild("Humanoid")
                    if humanoid and humanoid.Health > 0 then
                        local targetPart = char:FindFirstChild(AimbotConfig.TargetPart) or char:FindFirstChild("HumanoidRootPart")
                        if targetPart then
                            local pos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                            if onScreen then
                                local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                                if dist < AimbotConfig.FOVSize and verificarParede(targetPart, char) then
                                    table.insert(targets, {part = targetPart, position = targetPart.Position, dist = dist})
                                end
                            end
                        end
                    end
                end
            end
            
            table.sort(targets, function(a, b) return a.dist < b.dist end)
            
            if #targets > 0 then
                local target = targets[1]
                silentAimTarget = target
                camera.CFrame = CFrame.new(camera.CFrame.Position, target.position)
                LastCameraRotation = camera.CFrame.Rotation
            else
                silentAimTarget = nil
            end
        elseif not AimbotConfig.Enabled then
            silentAimTarget = nil
        end

        -- Aimbot Normal
        if AimbotConfig.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            if not CurrentTarget or not CurrentTarget.Part or not CurrentTarget.Part.Parent or 
               not CurrentTarget.Part.Parent:FindFirstChildOfClass("Humanoid") or 
               CurrentTarget.Part.Parent:FindFirstChildOfClass("Humanoid").Health <= 0 then
                local targets = {}
                local mousePos = UserInputService:GetMouseLocation()
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and deveMostrarParaJogador(p) then
                        local char = p.Character
                        local humanoid = char:FindFirstChild("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            local targetPart = char:FindFirstChild(AimbotConfig.TargetPart) or char:FindFirstChild("HumanoidRootPart")
                            if targetPart then
                                local pos, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                                if onScreen then
                                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                                    if dist < AimbotConfig.FOVSize and verificarParede(targetPart, char) then
                                        table.insert(targets, {part = targetPart, pos = targetPart.Position, dist = dist})
                                    end
                                end
                            end
                        end
                    end
                end
                table.sort(targets, function(a, b) return a.dist < b.dist end)
                CurrentTarget = #targets > 0 and targets[1] or nil
            end
            if CurrentTarget then
                local smoothFactor = AimbotConfig.Smoothness / 30
                if smoothFactor < 0.03 then smoothFactor = 0.03 end
                camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, CurrentTarget.pos), smoothFactor)
                LastCameraRotation = camera.CFrame.Rotation
            end
        else
            CurrentTarget = nil
        end

        -- ============================================================
        -- ESP DRAWING
        -- ============================================================
        for _, p in pairs(Players:GetPlayers()) do
            if p == player then continue end
            
            if not deveMostrarParaJogador(p) then
                if ESP[p] then
                    RemoveESPVisuals(p)
                end
                continue
            end
            
            local vis = ESP[p]
            if not vis then 
                CreateESPVisuals(p)
                vis = ESP[p]
                if not vis then continue end
            end

            -- Reset
            for _, c in pairs(vis.Corners) do if c then c.Visible = false end end
            if vis.Box then vis.Box.Visible = false end
            if vis.Tracer then vis.Tracer.Visible = false end
            if vis.Name then vis.Name.Visible = false end
            if vis.Distance then vis.Distance.Visible = false end
            if vis.HeadCircle then vis.HeadCircle.Visible = false end

            local char = p.Character
            if not char then 
                RemoveESPVisuals(p)
                continue 
            end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            local head = char:FindFirstChild("Head") or char:FindFirstChild("Cabeça")
            
            if not root or not hum or hum.Health <= 0 or not head then 
                RemoveESPVisuals(p)
                continue 
            end
            
            local rPos, onScreen = camera:WorldToViewportPoint(root.Position)
            if not onScreen then continue end
            
            local isVisible = verificarParede(head, char)
            local corDinamica = isVisible and GREEN or RED

            local topY = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y
            local botY = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0)).Y
            local h = math.abs(topY - botY)
            local w = h * 0.6
            local x = rPos.X - (w/2)

            -- Corner 2D
            if VisualConfig.Corner2D then
                local len = w / 4
                local corners = {
                    {Vector2.new(x, topY), Vector2.new(x + len, topY)},
                    {Vector2.new(x, topY), Vector2.new(x, topY + len)},
                    {Vector2.new(x + w, topY), Vector2.new(x + w - len, topY)},
                    {Vector2.new(x + w, topY), Vector2.new(x + w, topY + len)},
                    {Vector2.new(x, topY + h), Vector2.new(x + len, topY + h)},
                    {Vector2.new(x, topY + h), Vector2.new(x, topY + h - len)},
                    {Vector2.new(x + w, topY + h), Vector2.new(x + w - len, topY + h)},
                    {Vector2.new(x + w, topY + h), Vector2.new(x + w, topY + h - len)}
                }
                for i, corner in ipairs(corners) do
                    if vis.Corners[i] then
                        vis.Corners[i].From = corner[1]
                        vis.Corners[i].To = corner[2]
                        vis.Corners[i].Color = corDinamica
                        vis.Corners[i].Thickness = 2
                        vis.Corners[i].Visible = true
                    end
                end
            end

            -- Box ESP
            if VisualConfig.BoxESP and vis.Box then
                vis.Box.Size = Vector2.new(w, h)
                vis.Box.Position = Vector2.new(x, topY)
                vis.Box.Color = corDinamica
                vis.Box.Thickness = 1.5
                vis.Box.Visible = true
            end

            -- Tracers
            if VisualConfig.ShowTracers and vis.Tracer then
                local tracerYPos = VisualConfig.TracersPosition == "Em cima" and 0 or camera.ViewportSize.Y
                vis.Tracer.From = Vector2.new(camera.ViewportSize.X/2, tracerYPos)
                vis.Tracer.To = Vector2.new(rPos.X, rPos.Y)
                vis.Tracer.Color = WHITE
                vis.Tracer.Thickness = 1.5
                vis.Tracer.Visible = true
            end

            -- Name
            if VisualConfig.ShowName and vis.Name then
                vis.Name.Text = p.Name
                local headPos = camera:WorldToViewportPoint(head.Position)
                local footPos = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 2, 0))
                vis.Name.Position = VisualConfig.NamePosition == "Head" and 
                    Vector2.new(headPos.X, headPos.Y - 20) or 
                    Vector2.new(footPos.X, footPos.Y + 15)
                vis.Name.Color = WHITE
                vis.Name.Visible = true
            end

            -- Distance
            if VisualConfig.ShowDistance and vis.Distance then
                local dist = math.floor((root.Position - camera.CFrame.Position).Magnitude)
                vis.Distance.Text = dist .. "m"
                local headPos = camera:WorldToViewportPoint(head.Position)
                local footPos = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 2, 0))
                vis.Distance.Position = VisualConfig.DistancePosition == "Head" and 
                    Vector2.new(headPos.X, headPos.Y - 35) or 
                    Vector2.new(footPos.X, footPos.Y + 30)
                vis.Distance.Color = WHITE
                vis.Distance.Visible = true
            end

            -- HEAD ESP
            if VisualConfig.HeadESP and vis.HeadCircle then
                local headPart = char:FindFirstChild("Head") or char:FindFirstChild("Cabeça")
                if headPart then
                    local headPos, headOn = camera:WorldToViewportPoint(headPart.Position)
                    if headOn then
                        local distance = (headPart.Position - camera.CFrame.Position).Magnitude
                        local headSize = headPart.Size.Magnitude
                        local scale = 1 / math.max(distance, 1) * 1000
                        local porcentagem = 0.10
                        local radius = math.max(5, headSize * scale * porcentagem)
                        vis.HeadCircle.Position = Vector2.new(headPos.X, headPos.Y)
                        vis.HeadCircle.Color = WHITE
                        vis.HeadCircle.Radius = radius
                        vis.HeadCircle.Thickness = 2
                        vis.HeadCircle.Visible = true
                    end
                end
            end
        end
    end)
end)

