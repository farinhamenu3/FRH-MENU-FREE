local function RemoveESPVisuals(p)
    if ESP[p] then
        pcall(function()
            if ESP[p].Box then ESP[p].Box:Remove() end
            if ESP[p].Tracer then ESP[p].Tracer:Remove() end
            if ESP[p].Name then ESP[p].Name:Remove() end
            if ESP[p].Distance then ESP[p].Distance:Remove() end
            if ESP[p].HeadCircle then ESP[p].HeadCircle:Remove() end
            if ESP[p].Corners then
                for _, c in pairs(ESP[p].Corners) do
                    if c then pcall(function() c:Remove() end) end
                end
            end
        end)
        ESP[p] = nil
    end
end

local function criarESPparaJogador(p)
    if p == player then return end
    if not p then return end
    
    task.wait(0.5)
    
    if p.Character then
        CreateESPVisuals(p)
        print("✅ ESP criado para: " .. p.Name)
    end
    
    p.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if ESP[p] then RemoveESPVisuals(p) end
        CreateESPVisuals(p)
        print("✅ ESP recriado para: " .. p.Name)
    end)
end

