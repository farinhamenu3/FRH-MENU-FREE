-- ============================================================
-- INTERAÇÃO INSTANTÂNEA OTIMIZADA (NÃO TRAVA)
-- ============================================================
local function setupInstantInteract()
    pcall(function()
        -- Remove conexões antigas
        for _, conn in pairs(instantInteractConnections) do
            pcall(function() conn:Disconnect() end)
        end
        instantInteractConnections = {}
        
        if not PlayerConfig.InstantInteract then 
            print("❌ Interação Instantânea DESATIVADA")
            return 
        end
        
        print("⚡ Interação Instantânea ATIVADA (OTIMIZADA)")
        
        -- FUNÇÃO PARA CONFIGURAR UM PROMPT
        local function configurarPrompt(prompt)
            if prompt and prompt:IsA("ProximityPrompt") then
                prompt.HoldDuration = 0
                prompt.RequiresLineOfSight = false
                prompt.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
            end
        end
        
        -- FUNÇÃO PARA CONFIGURAR UM CLICK DETECTOR
        local function configurarClickDetector(detector)
            if detector and detector:IsA("ClickDetector") then
                detector.MaxActivationDistance = 100
            end
        end
        
        -- ESCANEIA APENAS OBJETOS RECENTES (NÃO O WORKSPACE INTEIRO)
        -- Usa um loop limitado para não travar
        local objetosVerificados = 0
        local limiteObjetos = 1000 -- Limite para não travar
        
        for _, obj in pairs(workspace:GetDescendants()) do
            objetosVerificados = objetosVerificados + 1
            if objetosVerificados > limiteObjetos then break end
            
            if obj:IsA("ProximityPrompt") then
                configurarPrompt(obj)
            elseif obj:IsA("ClickDetector") then
                configurarClickDetector(obj)
            end
        end
        
        print("✅ Configurados " .. objetosVerificados .. " objetos")
        
        -- MONITORA APENAS NOVOS OBJETOS (MAIS LEVE)
        local function onDescendantAdded(desc)
            if not PlayerConfig.InstantInteract then return end
            
            if desc:IsA("ProximityPrompt") then
                configurarPrompt(desc)
            elseif desc:IsA("ClickDetector") then
                configurarClickDetector(desc)
            end
        end
        
        -- Conecta apenas uma vez
        local conn = workspace.DescendantAdded:Connect(onDescendantAdded)
        table.insert(instantInteractConnections, conn)
        
        print("✅ Interação Instantânea configurada com sucesso!")
    end)
end

-- ============================================================
-- TPKILL
-- ============================================================
local function startTPKill()
    print("🔄 Iniciando TPKILL...")
    
    if tpKillRunning then
        print("⚠️ TPKILL já está rodando!")
        return
    end
    
    tpKillRunning = true
    
    tpKillTask = task.spawn(function()
        print("✅ TPKILL ATIVADO - Teleportando a cada " .. TPKILL_INTERVAL .. " segundos")
        
        while tpKillRunning and MicsConfig.TPKill do
            for i = 1, TPKILL_INTERVAL do
                if not tpKillRunning or not MicsConfig.TPKill then
                    break
                end
                task.wait(1)
            end
            
            if not tpKillRunning or not MicsConfig.TPKill then
                break
            end
            
            print("🔄 Buscando alvos para TPKILL...")
            
            local targets = {}
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local char = p.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local humanoid = char:FindFirstChild("Humanoid")
                    
                    if hrp and humanoid and humanoid.Health > 0 then
                        if not Whitelist[p.Name] then
                            if not isInSafeZone(hrp.Position) then
                                table.insert(targets, {
                                    hrp = hrp,
                                    player = p,
                                    name = p.Name
                                })
                            end
                        end
                    end
                end
            end
            
            if #targets > 0 then
                local target = targets[math.random(1, #targets)]
                local myChar = player.Character
                local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
                
                if myHRP and target.hrp then
                    myHRP.CanCollide = false
                    myHRP.CFrame = target.hrp.CFrame + Vector3.new(0, 2, 0)
                    task.wait(0.1)
                    myHRP.CanCollide = true
                    
                    print("🔄 TPKILL: Teleportado para " .. target.name .. " (Próximo teleporte em " .. TPKILL_INTERVAL .. "s)")
                else
                    print("⚠️ TPKILL: Não foi possível teleportar")
                end
            else
                print("⚠️ TPKILL: Nenhum alvo disponível")
            end
        end
        
        print("🛑 TPKILL: Loop finalizado")
        tpKillRunning = false
        tpKillTask = nil
    end)
end

local function stopTPKill()
    print("🛑 Parando TPKILL...")
    tpKillRunning = false
    
    if tpKillTask then 
        task.cancel(tpKillTask) 
        tpKillTask = nil 
    end
    
    print("❌ TPKILL DESATIVADO")
end

